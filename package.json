{
  "name": "hrpc-swift",
  "version": "1.0.0",
  "description": "Swift code generator for HRPC",
  "main": "index.js",
  "exports": {
    "./package": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "files": [
    "package.json",
    "index.js",
    "index.d.ts",
    "lib/*.js"
  ],
  "dependencies": {
    "hrpc": "^4.3.0"
  },
  "devDependencies": {
    "bare-rpc": "^1.2.0",
    "brittle": "^3.19.0",
    "compact-encoding": "^2.0.0",
    "hyperschema-swift": "^0.0.0",
    "lunte": "^1.2.0",
    "prettier": "^3.6.2",
    "prettier-config-holepunch": "^2.0.0"
  },
  "scripts": {
    "format": "prettier . --write",
    "lint": "prettier . --check",
    "test": "brittle test/swift-codegen.test.js",
    "test:cross-language": "brittle test/cross-language.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/hrpc-swift.git"
  },
  "author": "Holepunch",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/hrpc-swift/issues"
  },
  "homepage": "https://github.com/holepunchto/hrpc-swift"
}
