{
  "name": "hrpc-swift",
  "version": "0.2.0",
  "description": "Swift code generator for HRPC",
  "main": "index.js",
  "exports": {
    "./package": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "files": [
    "package.json",
    "index.js",
    "index.d.ts",
    "lib/*.js"
  ],
  "imports": {
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "child_process": {
      "bare": "bare-subprocess",
      "default": "child_process"
    }
  },
  "dependencies": {
    "hrpc": "^4.3.0"
  },
  "devDependencies": {
    "bare-fs": "^4.5.6",
    "bare-path": "^3.0.0",
    "bare-rpc": "^1.2.0",
    "bare-subprocess": "^5.2.3",
    "brittle": "^3.19.0",
    "compact-encoding": "^2.0.0",
    "hyperschema-swift": "^0.0.0",
    "prettier": "^3.6.2",
    "prettier-config-holepunch": "^2.0.0",
    "which-runtime": "^1.3.2"
  },
  "scripts": {
    "format": "prettier . --write",
    "lint": "prettier . --check",
    "test": "npm run test:node && npm run test:bare",
    "test:node": "brittle-node test.js",
    "test:bare": "brittle-bare test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/hrpc-swift.git"
  },
  "author": "Holepunch",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/hrpc-swift/issues"
  },
  "homepage": "https://github.com/holepunchto/hrpc-swift"
}
